# Copy this file to .streamlit/secrets.toml for local dev,
# or paste these keys into Streamlit Cloud's "Secrets" UI for hosting.
# DO NOT commit the real secrets.toml.

dashboard_password = "change-me"

YT_CLIENT_ID = "your-google-oauth-client-id.apps.googleusercontent.com"
YT_CLIENT_SECRET = "your-oauth-client-secret"
YT_REFRESH_TOKEN = "your-refresh-token-from-oauth-flow"
YT_CHANNEL_ID = "UCxxxxxxxxxxxxxxxxxxxxxx"
